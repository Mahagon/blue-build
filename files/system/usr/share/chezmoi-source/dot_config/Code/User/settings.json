{
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers"
  },
  "[powershell]": {
    "editor.defaultFormatter": "ms-vscode.powershell"
  },
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "[terraform-vars]": {
    "editor.defaultFormatter": "hashicorp.terraform"
  },
  "[terraform]": {
    "editor.defaultFormatter": "hashicorp.terraform"
  },
  "chat.agent.enabled": true,
  "githubPullRequests.codingAgent.enabled": true,
  "github.copilot.chat.reviewAgent.enabled": true,
  "diffEditor.codeLens": true,
  "diffEditor.experimental.showMoves": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "prettier.enable": true,
  "editor.fontFamily": "'Cascadia Code', monospace",
  "editor.fontLigatures": false,
  "editor.formatOnPaste": true,
  "editor.minimap.autohide": "mouseover",
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "boundary",
  "editor.suggest.preview": true,
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "files.associations": {
    "**/pipelines/*/*.yaml": "azure-pipelines",
    "*helmfile.yaml": "helm",
    "*helmfile.yaml.gotmpl": "helm"
  },
  "files.autoSave": "afterDelay",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "git.allowForcePush": true,
  "git.alwaysSignOff": true,
  "git.autoStash": true,
  "git.autofetch": true,
  "git.autofetchPeriod": 60,
  "git.branchPrefix": "PE-",
  "git.branchSortOrder": "committerdate",
  "git.branchWhitespaceChar": "_",
  "git.enableCommitSigning": true,
  "git.fetchOnPull": true,
  "git.pullTags": true,
  "git.rebaseWhenSync": true,
  "chat.tools.terminal.autoApprove": {
    "/^git (status|log|show\\b.*)$/": true
  },
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "text": "Use conventional commit message format."
    },
    {
      "text": "Add a description of the changes."
    },
    {
      "text": "Version upgrades are a chore and not a fix."
    }
  ],
  "github.copilot.chat.pullRequestDescriptionGeneration.instructions": [
    {
      "text": "Include every commit message in the pull request description."
    },
    {
      "text": "Include a description of the changes."
    },
    {
      "text": "The title for the pull request should be equal to the local branch name. But underscores should be replaced with spaces."
    },
    {
      "file": ".github/pull_request_template.md"
    }
  ],
  "github.copilot.enable": {
    "markdown": true,
    "enableAutoCompletions": true
  },
  "inlineChat.enableV2": true,
  "material-icon-theme.files.associations": {
    "*.helmfile.yaml": "helm",
    "helmfile.yaml": "helm",
    "*.helmfile.yaml.gotmpl": "helm",
    "helmfile.yaml.gotmpl": "helm"
  },
  "material-icon-theme.folders.associations": {
    "charts": "kubernetes",
    "k8s": "kubernetes",
    "python-modules": "python",
    "terraform": "terraform"
  },
  "projectManager.git.baseFolders": ["/var/home/daniel/Documents/src/"],
  "python.analysis.autoFormatStrings": true,
  "python.analysis.autoImportCompletions": true,
  "python.analysis.autoSearchPaths": true,
  "python.analysis.exclude": [".venv/**"],
  "python.analysis.inlayHints.callArgumentNames": "all",
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.inlayHints.pytestParameters": true,
  "python.analysis.typeCheckingMode": "strict",
  "python.languageServer": "Pylance",
  "python.terminal.activateEnvInCurrentTerminal": true,
  "python.terminal.activateEnvironment": true,
  "python.testing.pytestArgs": ["--numprocesses=auto"],
  "python.testing.pytestEnabled": true,
  "redhat.telemetry.enabled": false,
  "remote.defaultExtensionsIfInstalledLocally": [
    "GitHub.copilot",
    "GitHub.copilot-chat",
    "GitHub.vscode-pull-request-github"
  ],
  "security.workspace.trust.untrustedFiles": "open",
  "telemetry.telemetryLevel": "off",
  "terminal.integrated.enableMultiLinePasteWarning": "auto",
  "terraform.codelens.referenceCount": true,
  "terraform.experimentalFeatures.prefillRequiredFields": true,
  "terraform.experimentalFeatures.validateOnSave": true,
  "update.mode": "none",
  "vs-kubernetes": {
    "vs-kubernetes.crd-code-completion": "enabled"
  },
  "workbench.colorTheme": "GitHub Dark Default",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "none",
  "workbench.tree.enableStickyScroll": true,
  "powershell.codeFormatting.autoCorrectAliases": true,
  "powershell.codeFormatting.avoidSemicolonsAsLineTerminators": true,
  "powershell.codeFormatting.useConstantStrings": true,
  "powershell.codeFormatting.useCorrectCasing": true,
  "powershell.codeFormatting.whitespaceBetweenParameters": true,
  "powershell.promptToUpdatePowerShell": false,
  "workbench.activityBar.location": "top",
  "docker.extension.enableComposeLanguageServer": false,
  "docker.extension.dockerEngineAvailabilityPrompt": false,
  "chat.mcp.autostart": "newAndOutdated",
  "chat.mcp.discovery.enabled": {
    "claude-desktop": true,
    "windsurf": true,
    "cursor-global": true,
    "cursor-workspace": true
  },
  "chat.mcp.access": "all",
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true
    },
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "githubPullRequests.experimental.notificationsMarkPullRequests": "markAsDone",
  "githubPullRequests.defaultMergeMethod": "rebase",
  "atlascode.bitbucket.enabled": false,
  "atlascode.jira.lastCreatePreSelectedValues": {
    "siteId": "93edcfdf-a889-43d7-b2d7-f09086bf8db4",
    "projectKey": "PE",
    "issueTypeId": "10063"
  },
  "atlascode.jira.statusbar.showUser": false,
  "atlascode.jira.statusbar.showProduct": false,
  "atlascode.rovodev.enabled": false,
  "atlascode.jira.jqlList": [
    {
      "id": "554374d6-f3d5-40cc-b4dd-692537094ac3",
      "siteId": "93edcfdf-a889-43d7-b2d7-f09086bf8db4",
      "name": "Ready for Review",
      "query": "project = PE AND status = \"In review\" AND assignee IS EMPTY",
      "enabled": true,
      "monitor": true
    }
  ],
  "atlascode.jira.explorer.fetchAllQueryResults": true,
  "atlascode.jira.showCreateIssueProblems": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "chat.viewSessions.orientation": "stacked",
  "json.schemaDownload.trustedDomains": {
    "https://docs.renovatebot.com/": true
  },
  "atlascode.jira.enabled": true,
  "github.copilot.chat.customAgents.showOrganizationAndEnterpriseAgents": true,
  "claudeCode.preferredLocation": "panel",
  "chat.mcp.gallery.enabled": true,
  "workbench.secondarySideBar.defaultVisibility": "visible",
  "claudeCode.useTerminal": true,
  "workbench.colorCustomizations": {},
  "git.blame.ignoreWhitespace": true,
  "git.blame.statusBarItem.enabled": true
}
