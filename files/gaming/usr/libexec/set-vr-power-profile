#!/usr/bin/env bash
# Wrapper to safely set the AMD GPU power profile mode.
# Called by the vr-on / vr-off shell functions via sudo.
# Only accepts "vr" or "default" as arguments.
set -euo pipefail

if [[ "${1:-}" != "vr" && "${1:-}" != "default" ]]; then
    echo "Usage: set-vr-power-profile {vr|default}" >&2
    exit 1
fi

# Find the first GPU with power profile support (AMD discrete GPU)
pp_file=""
while IFS= read -r -d '' card; do
    candidate="$card/device/pp_power_profile_mode"
    if [[ -f "$candidate" ]]; then
        pp_file="$candidate"
        break
    fi
done < <(find /sys/class/drm -maxdepth 1 -name 'card[0-9]*' -not -name '*-*' -print0 | sort -z)

if [[ -z "$pp_file" ]]; then
    echo "Error: no AMD GPU with power profile support found" >&2
    exit 1
fi

# pp_power_profile_mode expects a numeric index, not a string.
# Parse the file to find the index for the requested mode.
case "$1" in
    vr)      mode_name="VR" ;;
    default) mode_name="BOOTUP_DEFAULT" ;;
esac

mode_index=$(awk -v name="$mode_name" '$NF == name { print $1; exit }' "$pp_file")

if [[ -z "$mode_index" ]]; then
    echo "Error: mode '$mode_name' not found in $pp_file" >&2
    echo "Available modes:" >&2
    cat "$pp_file" >&2
    exit 1
fi

echo "$mode_index" > "$pp_file"
