{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "prCreation": "immediate",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update version variables in install scripts",
      "managerFilePatterns": [
        "/scripts/.+\\.sh$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\n\\w+=\\\"(?<currentValue>.+?)\\\""
      ]
    }
  ]
}
