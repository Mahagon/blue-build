{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "abandonments:recommended",
    "group:recommended",
    ":configMigration",
    ":pinDevDependencies",
    ":gitSignOff"
  ],
  "prCreation": "immediate",
  "automerge": true,
  "automergeType": "pr",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update version variables in install scripts",
      "managerFilePatterns": ["/scripts/.+\\.sh$/"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+extractVersion=(?<extractVersion>\\S+))?\\n\\w+=\\\"(?<currentValue>.+?)\\\""
      ]
    }
  ]
}
